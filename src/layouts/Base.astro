---
import '../styles/tokens.css';
import '../styles/global.css';
import { site } from '../site';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  schema?: Record<string, unknown>;
  canonicalUrl?: string;
}

const { title, description, ogType = 'website', schema, canonicalUrl } = Astro.props;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, site.url);
const ogImage = new URL('/og-image.png', site.url);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      const stored = localStorage.getItem('theme');
      if (stored === 'light' || stored === 'dark') document.documentElement.dataset.theme = stored;
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={site.name}
      href={new URL('/rss.xml', site.url)}
    />
    <link
      rel="preload"
      href="/fonts/ibm-plex-sans-latin-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {schema && <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />}
    <!-- Google Search Console fallback: primary verification is a DNS TXT
         record in Cloudflare. Uncomment and fill only if that's unavailable.
    <meta name="google-site-verification" content="" /> -->
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header>
      <nav aria-label="Site">
        <a class="wordmark" href="/">{site.handle}.com</a>
        <div class="nav-links">
          <a href="/blog/">Blog</a>
          <a href="/rss.xml">RSS</a>
          <button class="theme-toggle" aria-label="Toggle colour scheme">
            <svg
              class="moon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
            </svg>
            <svg
              class="sun"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="12" cy="12" r="4"></circle>
              <path
                d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.3 11.3 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
              ></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer>
      <ul class="elsewhere">
        <li><a href={site.profiles.github}>GitHub ↗</a></li>
        <li><a href={site.profiles.linkedin}>LinkedIn ↗</a></li>
        <li><a href={site.profiles.substack}>Substack ↗</a></li>
      </ul>
      <p class="meta">© {year} {site.name}</p>
    </footer>
    <script is:inline>
      document.querySelector('.theme-toggle').addEventListener('click', () => {
        const root = document.documentElement;
        const dark = root.dataset.theme
          ? root.dataset.theme === 'dark'
          : matchMedia('(prefers-color-scheme: dark)').matches;
        const next = dark ? 'light' : 'dark';
        root.dataset.theme = next;
        localStorage.setItem('theme', next);
      });
    </script>
    {
      site.cloudflareAnalyticsToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={`{"token": "${site.cloudflareAnalyticsToken}"}`}
        />
      )
    }
  </body>
</html>

<style>
  header {
    padding-block: var(--space-l);
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-m);
  }

  .wordmark {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--text);
    text-decoration: none;
  }

  .wordmark:hover {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-l);
    font-size: var(--step--1);
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: var(--space-2xs);
    color: var(--text-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .theme-toggle:hover {
    color: var(--accent);
  }

  .sun {
    display: none;
  }

  html[data-theme='dark'] .sun {
    display: block;
  }

  html[data-theme='dark'] .moon {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    html:not([data-theme]) .sun {
      display: block;
    }

    html:not([data-theme]) .moon {
      display: none;
    }
  }

  footer {
    border-block-start: 1px solid var(--border);
    padding-block: var(--space-l);
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-m);
    flex-wrap: wrap;
  }

  .elsewhere {
    list-style: none;
    padding: 0;
    display: flex;
    gap: var(--space-l);
    flex-wrap: wrap;
    font-size: var(--step--1);
  }
</style>
