---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import { site } from '../site';
import { formatDate, isoDate } from '../dates';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, original } = post.data;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  url: original?.url ?? `${site.url}/blog/${post.id}/`,
  datePublished: isoDate(pubDate),
  ...(updatedDate && { dateModified: isoDate(updatedDate) }),
  author: {
    '@type': 'Person',
    name: site.name,
    url: site.url,
  },
};
---

<Base
  title={`${title} — ${site.name}`}
  description={description}
  ogType="article"
  schema={schema}
  canonicalUrl={original?.url}
>
  <article>
    <header>
      <h1>{title}</h1>
      <p class="meta">
        <time datetime={isoDate(pubDate)}>{formatDate(pubDate)}</time>
        {
          updatedDate && (
            <>
              {' · updated '}
              <time datetime={isoDate(updatedDate)}>{formatDate(updatedDate)}</time>
            </>
          )
        }
      </p>
      {
        original && (
          <p class="meta">
            Originally published on the <a href={original.url}>{original.venue} ↗</a>
          </p>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</Base>

<style>
  article > header {
    margin-block-end: var(--space-xl);
  }

  article > header .meta {
    margin-block-start: var(--space-xs);
  }
</style>
